<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="viewModel"
            type="com.partyhub.feature.themind.MindViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:padding="@dimen/margin_normal">

        <!-- Header: Level and Lives -->
        <TextView
            android:id="@+id/tvLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@{String.format(@string/mind_label_level, viewModel.gameState.level)}"
            android:textColor="@color/white"
            android:textSize="@dimen/text_card_title"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Misión 1" />

        <TextView
            android:id="@+id/tvLives"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@{String.format(@string/mind_label_lives, viewModel.gameState.lives)}"
            android:textColor="@color/text_lives"
            android:textSize="@dimen/text_body"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Vidas: 3" />

        <!-- Stack of played cards -->
        <TextView
            android:id="@+id/tvStackTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_xlarge"
            android:text="@string/mind_stack_title"
            android:textColor="@color/text_secondary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvLevel" />

        <TextView
            android:id="@+id/tvCurrentCard"
            android:layout_width="@dimen/card_width_mind"
            android:layout_height="@dimen/card_height_mind"
            android:layout_marginTop="@dimen/margin_small"
            android:background="@color/card_background"
            android:gravity="center"
            android:text="@{viewModel.gameState.playedCards.empty ? `?` : String.valueOf(viewModel.gameState.playedCards[viewModel.gameState.playedCards.size() - 1].number)}"
            android:textColor="@color/white"
            android:textSize="@dimen/text_card_number"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvStackTitle"
            tools:text="42" />

        <!-- Game Info / Status Message -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_large"
            android:gravity="center"
            android:text="@string/mind_status_revealing"
            android:textColor="@color/text_status_gold"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvCurrentCard"
            tools:visibility="visible" />

        <!-- Action Buttons for Players (Local Mode) -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/margin_large"
            android:layout_marginBottom="@dimen/margin_normal"
            app:layout_constraintBottom_toTopOf="@id/btnNextLevel"
            app:layout_constraintTop_toBottomOf="@id/tvStatus">

            <LinearLayout
                android:id="@+id/playerActionsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <!-- Level Transitions -->
        <Button
            android:id="@+id/btnResolve"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/mind_btn_resolve"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:visibility="visible" />

        <Button
            android:id="@+id/btnNextLevel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/mind_btn_next"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:visibility="visible" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
